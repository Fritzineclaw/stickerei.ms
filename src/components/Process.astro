---
const steps = [
  ["Anfragen", "Motiv, Textilwunsch und Menge senden."],
  ["Abstimmen", "Position, Größe, Garn und Machbarkeit klären."],
  ["Freigeben", "Vorlage prüfen und Produktion bestätigen."],
  ["Abholen", "Fertige Stücke erhalten oder Versand vereinbaren."],
];
---

<section class="section band" id="ablauf">
  <div class="container process">
    <div class="section-title">
      <p class="eyebrow">Ablauf</p>
      <h2>Vier Schritte bis zum fertigen Stick.</h2>
    </div>
    <ol>
      {steps.map(([title, text]) => (
        <li>
          <h3>{title}</h3>
          <p>{text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process {
    display: grid;
    gap: 32px;
    grid-template-columns: 0.8fr 1.2fr;
  }

  ol {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  li {
    display: grid;
    gap: 18px;
    grid-template-columns: 160px 1fr;
    padding: 24px 0;
    border-bottom: 1px solid var(--line);
  }

  li p {
    margin: 0;
  }

  @media (max-width: 840px) {
    .process,
    li {
      grid-template-columns: 1fr;
    }
  }
</style>
