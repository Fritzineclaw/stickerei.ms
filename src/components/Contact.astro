<section class="section contact" id="kontakt">
  <div class="container contact-grid">
    <div>
      <p class="eyebrow">Kontakt</p>
      <h2>Bereit für ein besticktes Stück?</h2>
      <p>
        Sende Motiv, gewünschte Textilien, Stückzahl und Termin. Für Logos sind
        Vektordaten ideal, aber auch Bilddateien reichen für eine erste Einschätzung.
      </p>
      <div class="contact-list">
        <a href="mailto:hallo@stickerei.ms">hallo@stickerei.ms</a>
        <a href="tel:+490000000000">+49 000 000000</a>
      </div>
    </div>
    <form name="anfrage" method="post">
      <label>
        Name
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        E-Mail
        <input type="email" name="email" autocomplete="email" required />
      </label>
      <label>
        Was soll bestickt werden?
        <textarea name="message" rows="5" required></textarea>
      </label>
      <button class="button" type="submit">Anfrage senden</button>
    </form>
  </div>
</section>

