---
const services = [
  ["Firmenkleidung", "Polos, Hoodies, Jacken und Workwear mit Logo, Namen oder Abteilung."],
  ["Vereine & Teams", "Einheitliche Looks für Mannschaften, Chöre, Clubs und Veranstaltungen."],
  ["Geschenke", "Personalisierte Handtücher, Taschen, Babydecken und besondere Einzelstücke."],
  ["Kleinserien", "Muster, Nachproduktionen und wiederkehrende Serien mit stabiler Qualität."],
];
---

<section class="section band" id="leistungen">
  <div class="container">
    <div class="section-title">
      <p class="eyebrow">Leistungen</p>
      <h2>Saubere Stickerei für Stücke, die lange bleiben.</h2>
      <p>
        Von der ersten Datei bis zum fertigen Textil: Wir beraten bei Material,
        Garnfarbe, Position und Größe, damit das Ergebnis zum Einsatz passt.
      </p>
    </div>
    <div class="service-grid">
      {services.map(([title, text], index) => (
        <article class="service-card">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .service-card {
    min-height: 210px;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .service-card span {
    display: inline-block;
    margin-bottom: 34px;
    color: var(--thread-dark);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .service-card p {
    margin-bottom: 0;
  }

  @media (max-width: 980px) {
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
